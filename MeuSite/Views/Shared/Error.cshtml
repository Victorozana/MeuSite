@model MeuSite.Models.ViewModels.ErrorViewModel
@{
    ViewData["Title"] = "Erro";
}

<div class="container-fluid p-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">
                    <h1 class="mb-0">
                        <i class="fas fa-exclamation-triangle"></i> Ocorreu um erro
                    </h1>
                </div>
                <div class="card-body">
                    <h2 class="text-danger mb-4">Ocorreu um erro ao processar sua solicitação.</h2>

                    @if (Model.ShowRequestId)
                    {
                        <div class="alert alert-info">
                            <strong>ID da Solicitação:</strong> <code>@Model.RequestId</code>
                            <br>
                            <small class="text-muted">Use este ID para referência ao contatar o suporte.</small>
                        </div>
                    }

                    <div class="row">
                        <div class="col-md-6">
                            <h5>O que fazer agora?</h5>
                            <ul>
                                <li>Tente atualizar a página</li>
                                <li>Verifique se os dados inseridos estão corretos</li>
                                <li>Volte para a página anterior e tente novamente</li>
                            </ul>
                        </div>
                        <div class="col-md-6">
                            <h5>Ações rápidas</h5>
                            <div class="d-grid gap-2">
                                <a href="javascript:history.back()" class="btn btn-outline-primary">
                                    <i class="fas fa-arrow-left"></i> Voltar para página anterior
                                </a>
                                <a asp-controller="Controle" asp-action="Index" class="btn btn-primary">
                                    <i class="fas fa-home"></i> Ir para página inicial
                                </a>
                            </div>
                        </div>
                    </div>

                    @if (ViewData["DevelopmentMode"] as bool? == true)
                    {
                        <div class="alert alert-warning mt-4">
                            <h5>Modo de Desenvolvimento</h5>
                            <p>
                                O ambiente de <strong>Desenvolvimento</strong> exibirá informações mais detalhadas sobre o erro ocorrido.
                            </p>
                            <p>
                                <strong>O ambiente de Desenvolvimento não deve ser habilitado para aplicativos implantados.</strong>
                                Isso pode resultar na exibição de informações confidenciais de exceções para usuários finais.
                                Para depuração local, habilite o ambiente de <strong>Desenvolvimento</strong> definindo a variável de ambiente <strong>ASPNETCORE_ENVIRONMENT</strong> como <strong>Development</strong>
                                e reiniciando o aplicativo.
                            </p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
