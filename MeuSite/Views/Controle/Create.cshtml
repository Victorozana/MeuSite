@model MeuSite.Models.Entities.ControleAno
@{
    ViewData["Title"] = "Novo Controle Anual";
}

<div class="container-fluid p-4">
    <div class="row mb-4">
        <div class="col">
            <h1 class="display-6 text-primary">@ViewData["Title"]</h1>
            <p class="lead">Crie um novo controle financeiro para o ano</p>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Informações do Controle</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        
                        <div class="form-group mb-3">
                            <label asp-for="Nome" class="form-label fw-bold">Nome do Controle</label>
                            <input asp-for="Nome" class="form-control form-control-lg" 
                                   placeholder="Ex: Planejamento 2026" />
                            <span asp-validation-for="Nome" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Ano" class="form-label fw-bold">Ano</label>
                            <input asp-for="Ano" class="form-control form-control-lg" 
                                   type="number" min="2020" max="2050" value="2026" />
                            <span asp-validation-for="Ano" class="text-danger"></span>
                        </div>

                        <div class="form-check mb-3">
                            <input asp-for="Ativo" class="form-check-input" type="checkbox" checked>
                            <label asp-for="Ativo" class="form-check-label">
                                Controle Ativo
                            </label>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary btn-lg flex-fill">
                                <i class="fas fa-save"></i> Criar Controle
                            </button>
                            <a asp-action="Index" class="btn btn-secondary btn-lg">
                                <i class="fas fa-arrow-left"></i> Voltar
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">Dicas</h5>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled mb-0">
                        <li class="mb-2">
                            <i class="fas fa-lightbulb text-warning"></i>
                            <strong>Nome:</strong> Use um nome descritivo como "Planejamento 2026"
                        </li>
                        <li class="mb-2">
                            <i class="fas fa-lightbulb text-warning"></i>
                            <strong>Ano:</strong> Cada controle deve representar um ano fiscal
                        </li>
                        <li class="mb-2">
                            <i class="fas fa-lightbulb text-warning"></i>
                            <strong>Ativo:</strong> Mantenha apenas o controle atual como ativo
                        </li>
                        <li class="mb-2">
                            <i class="fas fa-lightbulb text-warning"></i>
                            <strong>Após criar:</strong> Você poderá adicionar receitas, despesas e dívidas
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
