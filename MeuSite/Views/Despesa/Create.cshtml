@model MeuSite.Models.Entities.Despesa
@{
    ViewData["Title"] = "Nova Despesa";
}

<div class="container-fluid p-4">
    <div class="row mb-4">
        <div class="col">
            <h1 class="display-6 text-danger">@ViewData["Title"]</h1>
            <p class="lead">Adicione uma nova despesa, investimento ou doação</p>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0">Informações da Despesa</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label asp-for="Descricao" class="form-label fw-bold">Descrição</label>
                                    <input asp-for="Descricao" class="form-control form-control-lg" 
                                           placeholder="Ex: Aluguel, Supermercado, etc." />
                                    <span asp-validation-for="Descricao" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label asp-for="Valor" class="form-label fw-bold">Valor (R$)</label>
                                    <input asp-for="Valor" class="form-control form-control-lg money-input" 
                                           type="text" placeholder="0,00" />
                                    <span asp-validation-for="Valor" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label asp-for="Data" class="form-label fw-bold">Data da Despesa</label>
                                    <input asp-for="Data" class="form-control form-control-lg" type="date" />
                                    <span asp-validation-for="Data" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label asp-for="ControleAnoId" class="form-label fw-bold">Controle Anual</label>
                                    <select asp-for="ControleAnoId" class="form-select form-select-lg" asp-items="ViewBag.ControleAnos">
                                        <option value="">Selecione...</option>
                                    </select>
                                    <span asp-validation-for="ControleAnoId" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label asp-for="CategoriaId" class="form-label fw-bold">Categoria</label>
                                    <select asp-for="CategoriaId" class="form-select form-select-lg" asp-items="ViewBag.Categorias">
                                        <option value="">Selecione...</option>
                                    </select>
                                    <span asp-validation-for="CategoriaId" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label class="form-label fw-bold">Subcategoria</label>
                                    <select id="SubcategoriaId" name="SubcategoriaId" class="form-select form-select-lg">
                                        <option value="">Selecione uma categoria primeiro...</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-danger btn-lg flex-fill">
                                <i class="fas fa-save"></i> Salvar Despesa
                            </button>
                            <a asp-action="Index" class="btn btn-secondary btn-lg">
                                <i class="fas fa-arrow-left"></i> Cancelar
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">Dicas Rápidas</h5>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled mb-0">
                        <li class="mb-2">
                            <i class="fas fa-lightbulb text-warning"></i>
                            <strong>Descrição:</strong> Use nomes claros como "Aluguel Mensal"
                        </li>
                        <li class="mb-2">
                            <i class="fas fa-lightbulb text-warning"></i>
                            <strong>Categorias:</strong> Organize por tipo de gasto
                        </li>
                        <li class="mb-2">
                            <i class="fas fa-lightbulb text-warning"></i>
                            <strong>Subcategorias:</strong> Detalhe ainda mais (ex: Moradia → Aluguel)
                        </li>
                        <li class="mb-2">
                            <i class="fas fa-lightbulb text-warning"></i>
                            <strong>Data:</strong> Use a data real da despesa
                        </li>
                    </ul>
                </div>
            </div>

            <div class="card shadow-sm border-0 mt-3">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0">Categorias Comuns</h5>
                </div>
                <div class="card-body">
                    <div class="d-flex flex-wrap gap-2">
                        <span class="badge bg-danger">Moradia</span>
                        <span class="badge bg-warning">Alimentação</span>
                        <span class="badge bg-info">Transporte</span>
                        <span class="badge bg-secondary">Saúde</span>
                        <span class="badge bg-primary">Educação</span>
                        <span class="badge bg-success">Investimentos</span>
                        <span class="badge bg-dark">Doações</span>
                        <span class="badge bg-light text-dark">Outros</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        $(document).ready(function() {
            // Carregar subcategorias quando a categoria for selecionada
            $('#CategoriaId').change(function() {
                var categoriaId = $(this).val();
                var subcategoriaSelect = $('#SubcategoriaId');
                
                if (categoriaId) {
                    $.get('/Categoria/GetSubcategorias/' + categoriaId, function(data) {
                        subcategoriaSelect.empty();
                        subcategoriaSelect.append('<option value="">Selecione...</option>');
                        $.each(data, function(index, item) {
                            subcategoriaSelect.append('<option value="' + item.id + '">' + item.nome + '</option>');
                        });
                    });
                } else {
                    subcategoriaSelect.empty();
                    subcategoriaSelect.append('<option value="">Selecione uma categoria primeiro...</option>');
                }
            });
        });
    </script>
}
