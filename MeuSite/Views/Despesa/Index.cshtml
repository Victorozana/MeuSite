@model IEnumerable<MeuSite.Models.Entities.Despesa>
@{
    ViewData["Title"] = "Despesas";
}

<div class="container-fluid p-4">
    <div class="row mb-4">
        <div class="col">
            <h1 class="display-6 text-danger">@ViewData["Title"]</h1>
            <p class="lead">Gerencie suas despesas e acompanhe seus gastos</p>
        </div>
        <div class="col-auto">
            <div class="btn-group" role="group">
                @if (ViewBag.ControleAnoId != null)
                {
                    <a asp-action="Create" asp-route-controleAnoId="@ViewBag.ControleAnoId" class="btn btn-danger">
                        <i class="fas fa-plus"></i> Nova Despesa
                    </a>
                }
                <a asp-controller="Controle" asp-action="Index" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left"></i> Voltar
                </a>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <label class="form-label fw-bold">Filtrar por Ano:</label>
                    @{
                        var controleAnoId = ViewBag.ControleAnoId as int?;
                        var isSelected = controleAnoId?.ToString();
                    }
                    <select class="form-select" onchange="location.href='@Url.Action("Index")?controleAnoId=' + this.value">
                        <option value="">Todos os anos</option>
                        @if (ViewBag.ControleAnos != null)
                        {
                            foreach (var controle in ViewBag.ControleAnos)
                            {
                                if (isSelected == controle.Id.ToString())
                                {
                                    <option value="@controle.Id" selected>@controle.Nome (@controle.Ano)</option>
                                }
                                else
                                {
                                    <option value="@controle.Id">@controle.Nome (@controle.Ano)</option>
                                }
                            }
                        }
                    </select>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card bg-danger text-white">
                <div class="card-body">
                    <h5 class="card-title">Total Despesas</h5>
                    <h3 class="card-text">R$ @Model.Sum(d => d.Valor).ToString("N2")</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-info text-white">
                <div class="card-body">
                    <h5 class="card-title">Quantidade</h5>
                    <h3 class="card-text">@Model.Count()</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-primary text-white">
                <div class="card-body">
                    <h5 class="card-title">Média</h5>
                    <h3 class="card-text">R$ @(Model.Count() > 0 ? (Model.Sum(d => d.Valor) / Model.Count()).ToString("N2") : "0,00")</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-warning text-white">
                <div class="card-body">
                    <h5 class="card-title">Maior Despesa</h5>
                    <h3 class="card-text">R$ @(Model.Count() > 0 ? Model.Max(d => d.Valor).ToString("N2") : "0,00")</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header bg-danger text-white">
            <h5 class="mb-0"><i class="fas fa-list"></i> Lista de Despesas</h5>
        </div>
        <div class="card-body">
            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <div class="mb-4">
                        <i class="fas fa-receipt text-danger" style="font-size: 4rem;"></i>
                    </div>
                    <h3 class="text-muted">Nenhuma despesa cadastrada</h3>
                    <p class="text-muted">Comece adicionando suas primeiras despesas</p>
                    @if (ViewBag.ControleAnoId != null)
                    {
                        <a asp-action="Create" asp-route-controleAnoId="@ViewBag.ControleAnoId" class="btn btn-lg btn-danger">
                            <i class="fas fa-plus"></i> Adicionar Despesa
                        </a>
                    }
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-danger">
                            <tr>
                                <th>Data</th>
                                <th>Descrição</th>
                                <th>Valor</th>
                                <th>Categoria</th>
                                <th>Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var despesa in Model)
                            {
                                <tr>
                                    <td>@despesa.Data.ToString("dd/MM/yyyy")</td>
                                    <td>@despesa.Descricao</td>
                                    <td class="text-danger fw-bold">R$ @despesa.Valor.ToString("N2")</td>
                                    <td>
                                        @if (despesa.Categoria != null)
                                        {
                                            <span class="badge" style="background-color: @despesa.Categoria.Cor">@despesa.Categoria.Nome</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Sem categoria</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="btn-group" role="group">
                                            <a asp-action="Edit" asp-route-id="@despesa.Id" class="btn btn-sm btn-outline-primary">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@despesa.Id" class="btn btn-sm btn-outline-danger">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
