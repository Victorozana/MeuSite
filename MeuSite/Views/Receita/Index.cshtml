@model IEnumerable<MeuSite.Models.Entities.Receita>
@{
    ViewData["Title"] = "Receitas";
}

<div class="container-fluid p-4">
    <div class="row mb-4">
        <div class="col">
            <h1 class="display-6 text-success">@ViewData["Title"]</h1>
            <p class="lead">Gerencie suas receitas e acompanhe seus ganhos</p>
        </div>
        <div class="col-auto">
            <div class="btn-group" role="group">
                @if (ViewBag.ControleAnoId != null)
                {
                    <a asp-action="Create" asp-route-controleAnoId="@ViewBag.ControleAnoId" class="btn btn-success">
                        <i class="fas fa-plus"></i> Nova Receita
                    </a>
                }
                <a asp-controller="Controle" asp-action="Index" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left"></i> Voltar
                </a>
            </div>
        </div>
    </div>

    <!-- Filtro por Controle Ano -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <label class="form-label fw-bold">Filtrar por Ano:</label>
                    @{
                        var controleAnoId = ViewBag.ControleAnoId as int?;
                        var isSelected = controleAnoId?.ToString();
                    }
                    <select id="controleAnoFilter" class="form-select" onchange="location.href='@Url.Action("Index")?controleAnoId=' + this.value">
                        <option value="">Todos os anos</option>
                        @foreach (var controle in ViewBag.ControleAnos)
                        {
                            @if (isSelected == controle.Id.ToString())
                            {
                                <option value="@controle.Id" selected>@controle.Nome (@controle.Ano)</option>
                            }
                            else
                            {
                                <option value="@controle.Id">@controle.Nome (@controle.Ano)</option>
                            }
                        }
                    </select>
                </div>
            </div>
        </div>
    </div>

    <!-- Cards de Resumo -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <h5 class="card-title">Total Receitas</h5>
                    <h3 class="card-text">R$ @Model.Sum(r => r.Valor).ToString("N2")</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-info text-white">
                <div class="card-body">
                    <h5 class="card-title">Quantidade</h5>
                    <h3 class="card-text">@Model.Count()</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-primary text-white">
                <div class="card-body">
                    <h5 class="card-title">Média</h5>
                    <h3 class="card-text">R$ @(Model.Count() > 0 ? (Model.Sum(r => r.Valor) / Model.Count()).ToString("N2") : "0,00")</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-warning text-white">
                <div class="card-body">
                    <h5 class="card-title">Maior Receita</h5>
                    <h3 class="card-text">R$ @(Model.Count() > 0 ? Model.Max(r => r.Valor).ToString("N2") : "0,00")</h3>
                </div>
            </div>
        </div>
    </div>

    <!-- Lista de Receitas -->
    <div class="card">
        <div class="card-header bg-success text-white">
            <h5 class="mb-0"><i class="fas fa-list"></i> Lista de Receitas</h5>
        </div>
        <div class="card-body">
            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <div class="mb-4">
                        <i class="fas fa-money-bill-wave text-success" style="font-size: 4rem;"></i>
                    </div>
                    <h3 class="text-muted">Nenhuma receita cadastrada</h3>
                    <p class="text-muted">Comece adicionando suas primeiras receitas</p>
                    @if (ViewBag.ControleAnoId != null)
                    {
                        <a asp-action="Create" asp-route-controleAnoId="@ViewBag.ControleAnoId" class="btn btn-lg btn-success">
                            <i class="fas fa-plus"></i> Adicionar Receita
                        </a>
                    }
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-success">
                            <tr>
                                <th>Data</th>
                                <th>Descrição</th>
                                <th>Valor</th>
                                <th>Categoria</th>
                                <th>Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var receita in Model)
                            {
                                <tr>
                                    <td>@receita.Data.ToString("dd/MM/yyyy")</td>
                                    <td>@receita.Descricao</td>
                                    <td class="text-success fw-bold">R$ @receita.Valor.ToString("N2")</td>
                                    <td>
                                        @if (receita.Categoria != null)
                                        {
                                            <span class="badge" style="background-color: @receita.Categoria.Cor">@receita.Categoria.Nome</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Sem categoria</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="btn-group" role="group">
                                            <a asp-action="Edit" asp-route-id="@receita.Id" class="btn btn-sm btn-outline-primary">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@receita.Id" class="btn btn-sm btn-outline-danger">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Auto-refresh a cada 30 segundos
        setTimeout(function() {
            window.location.reload();
        }, 30000);
    </script>
}
