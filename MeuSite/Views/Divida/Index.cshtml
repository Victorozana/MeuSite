@model IEnumerable<MeuSite.Models.Entities.Divida>
@{
    ViewData["Title"] = "Dívidas";
}

<div class="container-fluid p-4">
    <div class="row mb-4">
        <div class="col">
            <h1 class="display-6 text-warning">@ViewData["Title"]</h1>
            <p class="lead">Gerencie suas dívidas parceladas e pagamentos</p>
        </div>
        <div class="col-auto">
            <div class="btn-group" role="group">
                @if (ViewBag.ControleAnoId != null)
                {
                    <a asp-action="Create" asp-route-controleAnoId="@ViewBag.ControleAnoId" class="btn btn-warning">
                        <i class="fas fa-plus"></i> Nova Dívida
                    </a>
                }
                <a asp-controller="Controle" asp-action="Index" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left"></i> Voltar
                </a>
            </div>
        </div>
    </div>

    <!-- Filtro por Controle Ano -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <label class="form-label fw-bold">Filtrar por Ano:</label>
                    @{
                        var controleAnoId = ViewBag.ControleAnoId as int?;
                        var isSelected = controleAnoId?.ToString();
                    }
                    <select id="controleAnoFilter" class="form-select" onchange="location.href='@Url.Action("Index")?controleAnoId=' + this.value">
                        <option value="">Todos os anos</option>
                        @foreach (var controle in ViewBag.ControleAnos)
                        {
                            @if (isSelected == controle.Id.ToString())
                            {
                                <option value="@controle.Id" selected>@controle.Nome (@controle.Ano)</option>
                            }
                            else
                            {
                                <option value="@controle.Id">@controle.Nome (@controle.Ano)</option>
                            }
                        }
                    </select>
                </div>
            </div>
        </div>
        <div class="col-md-8">
            <div class="card bg-warning text-dark">
                <div class="card-body">
                    <div class="row text-center">
                        <div class="col">
                            <h5>Total de Dívidas</h5>
                            <h2>@Model.Sum(d => d.ValorTotal):C</h2>
                        </div>
                        <div class="col">
                            <h5>Parcelas Pagas</h5>
                            <h2>@Model.SelectMany(d => d.Parcelas).Count(p => p.Paga)</h2>
                        </div>
                        <div class="col">
                            <h5>Parcelas Abertas</h5>
                            <h2>@Model.SelectMany(d => d.Parcelas).Count(p => !p.Paga)</h2>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <div class="mb-4">
                <i class="fas fa-credit-card text-warning" style="font-size: 4rem;"></i>
            </div>
            <h3 class="text-muted">Nenhuma dívida cadastrada</h3>
            <p class="text-muted">Adicione sua primeira dívida parcelada para controlar seus pagamentos</p>
            @if (ViewBag.ControleAnoId != null)
            {
                <a asp-action="Create" asp-route-controleAnoId="@ViewBag.ControleAnoId" class="btn btn-lg btn-warning">
                    <i class="fas fa-plus"></i> Adicionar Dívida
                </a>
            }
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-header bg-warning text-dark">
                <h5 class="mb-0">
                    <i class="fas fa-list"></i> Lista de Dívidas
                    <span class="badge bg-dark float-end">@Model.Count() itens</span>
                </h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Dívida</th>
                                <th>Total</th>
                                <th>Parcelas</th>
                                <th>Vencimento</th>
                                <th>Status</th>
                                <th class="text-center">Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var divida in Model)
                            {
                                var parcelasPagas = divida.Parcelas.Count(p => p.Paga);
                                var totalParcelas = divida.Parcelas.Count;
                                var percentualPago = totalParcelas > 0 ? (parcelasPagas * 100 / totalParcelas) : 0;
                                
                                <tr>
                                    <td>
                                        <strong>@divida.Descricao</strong>
                                        @if (divida.Categoria != null)
                                        {
                                            <br><span class="badge" style="background-color: @(divida.Categoria.Cor ?? "#ffc107")">@divida.Categoria.Nome</span>
                                        }
                                    </td>
                                    <td>
                                        <strong>@divida.ValorTotal:C</strong>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <span>@parcelasPagas/@totalParcelas</span>
                                            <div class="progress ms-2 flex-grow-1" style="height: 8px;">
                                                <div class="progress-bar bg-success" style="width: @percentualPago%"></div>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        @divida.DataPrimeiroVencimento.ToString("dd/MM/yyyy")
                                    </td>
                                    <td>
                                        @if (parcelasPagas == totalParcelas)
                                        {
                                            <span class="badge bg-success">Paga</span>
                                        }
                                        else if (parcelasPagas > 0)
                                        {
                                            <span class="badge bg-warning">Em andamento</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Aberta</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group" role="group">
                                            <a asp-action="Details" asp-route-id="@divida.Id" class="btn btn-sm btn-outline-info">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@divida.Id" class="btn btn-sm btn-outline-primary">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@divida.Id" class="btn btn-sm btn-outline-danger">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr>
                                <th colspan="2" class="text-end">Total Geral:</th>
                                <th colspan="4">
                                    <strong class="text-warning">@Model.Sum(d => d.ValorTotal):C</strong>
                                </th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    }
</div>
