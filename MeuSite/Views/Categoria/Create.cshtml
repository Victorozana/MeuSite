@model MeuSite.Models.Entities.Categoria
@{
    ViewData["Title"] = "Nova Categoria";
}

<div class="container-fluid p-4">
    <div class="row mb-4">
        <div class="col">
            <h1 class="display-6 text-info">@ViewData["Title"]</h1>
            <p class="lead">Crie uma nova categoria para organizar suas finanças</p>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">Informações da Categoria</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label asp-for="Nome" class="form-label fw-bold">Nome da Categoria</label>
                                    <input asp-for="Nome" class="form-control form-control-lg" 
                                           placeholder="Ex: Moradia, Alimentação, Transporte" />
                                    <span asp-validation-for="Nome" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label asp-for="Cor" class="form-label fw-bold">Cor</label>
                                    <div class="input-group">
                                        <input asp-for="Cor" class="form-control form-control-lg" 
                                               type="color" value="#17a2b8" />
                                        <input type="text" id="corHex" class="form-control form-control-lg" 
                                               value="#17a2b8" readonly />
                                    </div>
                                    <small class="text-muted">Escolha uma cor para identificar visualmente a categoria</small>
                                    <span asp-validation-for="Cor" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="ControleAnoId" class="form-label fw-bold">Controle Anual</label>
                            <select asp-for="ControleAnoId" class="form-select form-select-lg" asp-items="ViewBag.ControleAnos">
                                <option value="">Selecione...</option>
                            </select>
                            <span asp-validation-for="ControleAnoId" class="text-danger"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-info btn-lg flex-fill">
                                <i class="fas fa-save"></i> Criar Categoria
                            </button>
                            <a asp-action="Index" class="btn btn-secondary btn-lg">
                                <i class="fas fa-arrow-left"></i> Cancelar
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0">Dicas Rápidas</h5>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled mb-0">
                        <li class="mb-2">
                            <i class="fas fa-lightbulb text-warning"></i>
                            <strong>Nome:</strong> Use categorias claras e objetivas
                        </li>
                        <li class="mb-2">
                            <i class="fas fa-lightbulb text-warning"></i>
                            <strong>Cor:</strong> Use cores diferentes para facilitar identificação
                        </li>
                        <li class="mb-2">
                            <i class="fas fa-lightbulb text-warning"></i>
                            <strong>Subcategorias:</strong> Após criar, adicione subcategorias para detalhar
                        </li>
                        <li class="mb-2">
                            <i class="fas fa-lightbulb text-warning"></i>
                            <strong>Ano:</strong> Cada categoria pertence a um controle anual
                        </li>
                    </ul>
                </div>
            </div>

            <div class="card shadow-sm border-0 mt-3">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">Categorias Sugeridas</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <h6>Para Receitas:</h6>
                        <div class="d-flex flex-wrap gap-2">
                            <span class="badge bg-success">Salário</span>
                            <span class="badge bg-info">Vendas</span>
                            <span class="badge bg-primary">Investimentos</span>
                            <span class="badge bg-secondary">Freelance</span>
                        </div>
                    </div>
                    <div>
                        <h6>Para Despesas:</h6>
                        <div class="d-flex flex-wrap gap-2">
                            <span class="badge bg-danger">Moradia</span>
                            <span class="badge bg-warning">Alimentação</span>
                            <span class="badge bg-info">Transporte</span>
                            <span class="badge bg-secondary">Saúde</span>
                            <span class="badge bg-primary">Educação</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        $(document).ready(function() {
            // Sincronizar os campos de cor
            $('#Cor').on('input change', function() {
                $('#corHex').val($(this).val());
            });
            
            // Permitir edição do campo hex
            $('#corHex').on('input', function() {
                var hex = $(this).val();
                if (/^#[0-9A-F]{6}$/i.test(hex)) {
                    $('#Cor').val(hex);
                }
            });
        });
    </script>
}
